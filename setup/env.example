# ── AI Receptionist Environment Variables ─────────────────────────
# Copy this file to .env and fill in your actual values

# OpenRouter API key (get from openrouter.ai)
OPENROUTER_API_KEY=your_openrouter_key_here

# AI Model (free tier on OpenRouter)
AI_MODEL=qwen/qwen3-235b-a22b:free

# Hindsight Cloud API key (promo code: MEMHACK6 for free credits)
HINDSIGHT_API_KEY=your_hindsight_key_here

# Set to "true" to enable verbose logging
DEBUG=false

# Optional: Customize your business description
# BUSINESS_CONTEXT=You are a receptionist for Acme Corp...
